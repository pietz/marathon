{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "python": "3.12",
    "uv": "latest"
  },
  "steps": {
    "python-install": {
      "inputs": [{ "step": "build" }],
      "commands": ["uv sync --frozen --no-dev"]
    }
  },
  "deploy": {
    "inputs": ["...", { "step": "python-install" }],
    "startCommand": "uv run uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
  }
}
